# Automatically load the Nix development environment when entering this directory
# Requires direnv: https://direnv.net/
# Install with: nix-env -iA nixpkgs.direnv (or your package manager)
# Hook into your shell: https://direnv.net/docs/hook.html

use flake

# Watch additional files for changes
watch_file flake.nix
watch_file flake.lock

# Load .env file if it exists (for additional project-specific variables)
if [ -f .env ]; then
  dotenv .env
fi
